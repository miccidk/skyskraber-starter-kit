# Opret en OAuth-app på https://www.skyskraber.dk under din profil -> Developer

# VITE_ prefix = synlig i browseren (kun client_id og public config)
VITE_CLIENT_ID=din_client_id
VITE_REDIRECT_URI=http://localhost:5180/callback
VITE_API_BASE_URL=https://www.skyskraber.dk

# Ingen VITE_ prefix = kun server-side (hemmeligheder)
CLIENT_SECRET=din_client_secret
