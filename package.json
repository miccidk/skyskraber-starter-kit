		"@tanstack/react-router": "^1.167.1",
		"@tanstack/react-virtual": "^3.13.6",
		"@tanstack/router-plugin": "^1.166.10",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"hono": "^4.12.8",
		"lucide-react": "^0.511.0",
